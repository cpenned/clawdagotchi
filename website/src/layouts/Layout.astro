---
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/700.css';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Clawdagotchi — Your Claude Code Companion',
  description = 'A virtual crab companion for Claude Code. Watch it react to your sessions, earn XP, unlock accessories, and keep you company while you code.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://clawdagotchi.com/" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://clawdagotchi.com/og-image.png" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="https://clawdagotchi.com/og-image.png" />
  </head>
  <body>
    <!-- Top glow -->
    <div aria-hidden="true" style="position:fixed;top:0;left:50%;transform:translateX(-50%);width:800px;height:400px;pointer-events:none;z-index:0;background:radial-gradient(ellipse at center top,rgba(217,119,87,0.07) 0%,transparent 70%);"></div>
    <!-- Top grid -->
    <div aria-hidden="true" style="position:fixed;top:0;left:0;right:0;height:350px;pointer-events:none;z-index:1;background-image:radial-gradient(circle,rgba(217,119,87,0.15) 1px,transparent 1px);background-size:8px 8px;-webkit-mask-image:linear-gradient(to bottom,rgba(0,0,0,0.8),transparent);mask-image:linear-gradient(to bottom,rgba(0,0,0,0.8),transparent)"></div>
    <!-- Bottom glow -->
    <div aria-hidden="true" style="position:fixed;bottom:0;left:50%;transform:translateX(-50%);width:800px;height:400px;pointer-events:none;z-index:0;background:radial-gradient(ellipse at center bottom,rgba(217,119,87,0.07) 0%,transparent 70%);"></div>
    <!-- Bottom grid -->
    <div aria-hidden="true" style="position:fixed;bottom:0;left:0;right:0;height:350px;pointer-events:none;z-index:1;background-image:radial-gradient(circle,rgba(217,119,87,0.15) 1px,transparent 1px);background-size:8px 8px;-webkit-mask-image:linear-gradient(to top,rgba(0,0,0,0.8),transparent);mask-image:linear-gradient(to top,rgba(0,0,0,0.8),transparent)"></div>
    <div style="position:relative;z-index:10">
      <slot />
    </div>
  </body>
</html>
