---
import TamagotchiDemo from './TamagotchiDemo.tsx'
---

<section class="min-h-screen flex flex-col items-center justify-center px-6 pt-24 pb-16">
  <div class="max-w-4xl mx-auto text-center">
    <!-- App icon (matches macOS icon exactly) -->
    <div class="mb-6">
      <svg width="80" height="80" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg" class="mx-auto rounded-2xl" style="box-shadow: 0 8px 32px rgba(217,119,87,0.3)">
        <!-- Salmon bg -->
        <rect width="100" height="100" rx="22" fill="#D97757"/>
        <!-- Light egg -->
        <ellipse cx="50" cy="48" rx="34" ry="40" fill="#F8D0C4"/>
        <!-- Crab body (scaled from 66x52 viewBox) -->
        <rect x="32" y="28" width="36" height="26" fill="#D97757"/>
        <!-- Antennae -->
        <rect x="26" y="34" width="4" height="8" fill="#D97757"/>
        <rect x="70" y="34" width="4" height="8" fill="#D97757"/>
        <!-- Legs -->
        <rect x="32" y="54" width="4" height="8" fill="#D97757"/>
        <rect x="40" y="54" width="4" height="8" fill="#D97757"/>
        <rect x="56" y="54" width="4" height="8" fill="#D97757"/>
        <rect x="64" y="54" width="4" height="8" fill="#D97757"/>
        <!-- Eyes (cutout) -->
        <rect x="38" y="34" width="5" height="5" fill="#F8D0C4"/>
        <rect x="57" y="34" width="5" height="5" fill="#F8D0C4"/>
        <!-- Buttons -->
        <circle cx="41" cy="80" r="3.5" fill="#D97757"/>
        <circle cx="50" cy="80" r="3.5" fill="#D97757"/>
        <circle cx="59" cy="80" r="3.5" fill="#D97757"/>
      </svg>
    </div>

    <!-- Badge -->
    <div class="inline-flex items-center gap-2 bg-[var(--card)] border border-[var(--border)] rounded-full px-4 py-1.5 text-sm text-[var(--text-secondary)] mb-8">
      <span class="w-2 h-2 rounded-full bg-[var(--accent)] inline-block"></span>
      macOS app · Free & open source
    </div>

    <!-- Headline -->
    <h1 class="font-mono-heading font-bold text-5xl md:text-7xl text-white leading-tight mb-6">
      Your Claude Code<br />
      <span style="color: var(--accent)">companion</span>
    </h1>

    <!-- Subtitle -->
    <p class="text-xl text-[var(--text-secondary)] max-w-2xl mx-auto mb-10 leading-relaxed">
      A virtual crab that lives in your menu bar, watches your Claude Code sessions,
      reacts to your work, and keeps you company while you build.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-16">
      <a
        href="https://github.com/cpenned/clawdagotchi/releases/latest/download/Clawdagotchi.dmg"
        id="download"
        class="flex items-center gap-2 bg-[var(--accent)] hover:bg-[var(--accent-hover)] text-white px-6 py-3 rounded-xl font-medium text-base transition-colors"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        Download for macOS
      </a>
      <a
        href="https://github.com/cpenned/clawdagotchi"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 border border-[rgba(255,255,255,0.12)] hover:border-[rgba(255,255,255,0.24)] text-white px-6 py-3 rounded-xl font-medium text-base transition-colors"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
        </svg>
        View on GitHub
      </a>
    </div>

    <!-- Demo -->
    <TamagotchiDemo client:visible />
  </div>
</section>
