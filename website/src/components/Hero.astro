---
import TamagotchiDemo from "./TamagotchiDemo.tsx";
import AppIcon from "../assets/icons/appicon.svg";
---

<section
  class="min-h-screen flex flex-col items-center justify-center px-6 pt-24 pb-16"
>
  <div
    class="max-w-6xl mx-auto w-full flex flex-col lg:flex-row lg:items-center mt-6 lg:gap-16 lg:mt-16"
  >
    <!-- Left: text content -->
    <div class="flex-1 min-w-0 text-center lg:text-left">
      <AppIcon class="size-30 rounded-3xl mx-auto lg:mx-0" />

      <h1
        class="mt-4 font-mono-heading font-bold text-5xl md:text-6xl text-white leading-tighter text-balance mb-6"
      >
        Your Claude Code<br />
        <span style="color: var(--accent)">Companion</span>
      </h1>

      <p
        class="text-xl text-(--text-secondary) max-w-2xl mx-auto lg:mx-0 mb-10 leading-relaxed text-pretty"
      >
        A Tamagotchi-style floating widget that watches your Claude Code
        sessions, reacts to your work, and needs your care while you build.
      </p>

      <!-- CTAs -->
      <div
        class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-4"
      >
        <a
          href="https://github.com/cpenned/clawdagotchi/releases/latest/download/Clawdagotchi.dmg"
          id="download"
          class="flex items-center gap-2 bg-(--accent) hover:bg-(--accent-hover) text-white px-6 py-3 rounded-xl font-medium text-base transition-colors"
        >
          <svg
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
            <polyline points="7 10 12 15 17 10"></polyline>
            <line x1="12" y1="15" x2="12" y2="3"></line>
          </svg>
          Download for macOS
        </a>
        <a
          href="https://github.com/cpenned/clawdagotchi"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 border border-[rgba(255,255,255,0.12)] hover:border-[rgba(255,255,255,0.24)] text-white px-6 py-3 rounded-xl font-medium text-base transition-colors"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"
            ></path>
          </svg>
          View on GitHub
        </a>
      </div>
    </div>

    <!-- Right: Demo -->
    <div class="flex-shrink-0 flex justify-center mt-16 lg:mt-0">
      <TamagotchiDemo client:visible />
    </div>
  </div>
</section>
