---
---

<nav id="nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 no-underline">
      <svg width="28" height="28" viewBox="0 0 66 52" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- Matches macOS app icon crab exactly: viewBox 66x52 -->
        <!-- Antennae -->
        <rect x="0" y="13" width="6" height="13" fill="#D97757"/>
        <rect x="60" y="13" width="6" height="13" fill="#D97757"/>
        <!-- Body -->
        <rect x="6" y="0" width="54" height="39" fill="#D97757"/>
        <!-- Legs (4) -->
        <rect x="6" y="39" width="6" height="13" fill="#D97757"/>
        <rect x="18" y="39" width="6" height="13" fill="#D97757"/>
        <rect x="42" y="39" width="6" height="13" fill="#D97757"/>
        <rect x="54" y="39" width="6" height="13" fill="#D97757"/>
        <!-- Eyes (dark) -->
        <rect x="14" y="12" width="6" height="7" fill="#0A0A0A"/>
        <rect x="46" y="12" width="6" height="7" fill="#0A0A0A"/>
      </svg>
      <span class="font-mono-heading font-bold text-white text-lg tracking-tight">Clawdagotchi</span>
    </a>

    <!-- Right side -->
    <div class="flex items-center gap-4">
      <a
        href="https://github.com/cpenned/clawdagotchi"
        target="_blank"
        rel="noopener noreferrer"
        class="text-[var(--text-secondary)] hover:text-white transition-colors text-sm flex items-center gap-1.5"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
        </svg>
        GitHub
      </a>
      <a
        href="https://github.com/cpenned/clawdagotchi/releases/latest"
        class="bg-[var(--accent)] hover:bg-[var(--accent-hover)] text-white px-4 py-2 rounded-lg text-sm font-medium transition-colors"
      >
        Download
      </a>
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('nav')!
  let scrolled = false

  window.addEventListener('scroll', () => {
    const isScrolled = window.scrollY > 20
    if (isScrolled !== scrolled) {
      scrolled = isScrolled
      if (scrolled) {
        nav.style.background = 'rgba(10, 10, 10, 0.85)'
        nav.style.backdropFilter = 'blur(12px)'
        nav.style.borderBottom = '1px solid rgba(255,255,255,0.06)'
      } else {
        nav.style.background = ''
        nav.style.backdropFilter = ''
        nav.style.borderBottom = ''
      }
    }
  })
</script>
