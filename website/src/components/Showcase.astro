---
const accessories = [
  { name: 'None', level: 1, color: '#D97757' },
  { name: 'Bow Tie', level: 2, color: '#D97757' },
  { name: 'Party Hat', level: 3, color: '#D97757' },
  { name: 'Sunglasses', level: 4, color: '#D97757' },
  { name: 'Top Hat', level: 5, color: '#D97757' },
  { name: 'Crown', level: 6, color: '#D97757' },
  { name: 'Headphones', level: 7, color: '#D97757' },
  { name: '✨ Max', level: 8, color: '#D97757' },
]

const accessoryEmojis: Record<string, string> = {
  'None': '',
  'Bow Tie': '🎀',
  'Party Hat': '🎉',
  'Sunglasses': '🕶️',
  'Top Hat': '🎩',
  'Crown': '👑',
  'Headphones': '🎧',
  '✨ Max': '✨',
}
---

<section class="py-24 px-6 overflow-hidden">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="font-mono-heading font-bold text-4xl md:text-5xl text-white mb-4">
        Dress up your crab
      </h2>
      <p class="text-[var(--text-secondary)] text-lg max-w-xl mx-auto">
        Level up to unlock new accessories. Show off your dedication.
      </p>
    </div>

    <div class="flex gap-4 overflow-x-auto pb-4 justify-start md:justify-center scrollbar-hide">
      {accessories.map(acc => (
        <div class="flex-shrink-0 flex flex-col items-center gap-3">
          <div class="w-20 h-20 bg-[var(--card)] border border-[var(--border)] rounded-2xl flex flex-col items-center justify-center gap-1 hover:border-[rgba(217,119,87,0.3)] transition-colors">
            <!-- Mini crab SVG -->
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none">
              <!-- Body -->
              <rect x="9" y="13" width="18" height="13" rx="3" fill="#D97757"/>
              <!-- Claws -->
              <rect x="3" y="12" width="6" height="5" rx="2" fill="#D97757"/>
              <rect x="27" y="12" width="6" height="5" rx="2" fill="#D97757"/>
              <!-- Legs -->
              <rect x="10" y="26" width="3" height="5" rx="1.5" fill="#D97757"/>
              <rect x="16.5" y="26" width="3" height="5" rx="1.5" fill="#D97757"/>
              <rect x="23" y="26" width="3" height="5" rx="1.5" fill="#D97757"/>
              <!-- Eyes -->
              <rect x="13" y="16" width="4" height="4" rx="1" fill="#1A1A1A"/>
              <rect x="19" y="16" width="4" height="4" rx="1" fill="#1A1A1A"/>
              {/* Accessory overlay */}
              {acc.name === 'Sunglasses' && (
                <>
                  <rect x="11" y="14" width="6" height="7" rx="1" fill="none" stroke="white" stroke-width="1"/>
                  <rect x="19" y="14" width="6" height="7" rx="1" fill="none" stroke="white" stroke-width="1"/>
                  <line x1="17" y1="17.5" x2="19" y2="17.5" stroke="white" stroke-width="1"/>
                </>
              )}
              {acc.name === 'Bow Tie' && (
                <text x="18" y="12" text-anchor="middle" font-size="8" fill="#ff6eb4">🎀</text>
              )}
              {acc.name === 'Crown' && (
                <text x="18" y="11" text-anchor="middle" font-size="9">👑</text>
              )}
              {acc.name === 'Top Hat' && (
                <text x="18" y="10" text-anchor="middle" font-size="9">🎩</text>
              )}
              {acc.name === 'Party Hat' && (
                <text x="18" y="10" text-anchor="middle" font-size="9">🎉</text>
              )}
              {acc.name === 'Headphones' && (
                <text x="18" y="12" text-anchor="middle" font-size="9">🎧</text>
              )}
              {acc.name === '✨ Max' && (
                <text x="18" y="10" text-anchor="middle" font-size="9">✨</text>
              )}
            </svg>
          </div>
          <div class="text-center">
            <p class="text-white text-xs font-medium">{acc.name}</p>
            <p class="text-[var(--text-secondary)] text-xs">LV {acc.level}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
</style>
