---
const features = [
  {
    icon: '🔄',
    title: 'Live Session Tracking',
    description: 'Your crab watches Claude Code work and reacts with animated expressions in real-time.',
  },
  {
    icon: '🔐',
    title: 'Permission Handling',
    description: 'Approve or deny tool permissions directly from the floating widget without switching windows.',
  },
  {
    icon: '🍴',
    title: 'Pet Care',
    description: 'Feed, pet, and poke your crab. Watch hunger and happiness drain over time if you neglect it.',
  },
  {
    icon: '⬆️',
    title: 'Level Up',
    description: 'Earn XP from coding sessions and interactions. Level up to unlock 8 unique accessories.',
  },
  {
    icon: '🏆',
    title: 'Achievements',
    description: '12 badges to unlock — from your first poke to 30-day coding streaks and beyond.',
  },
  {
    icon: '🎮',
    title: 'Mini-Games',
    description: 'Simon Says pops up randomly. Catch bugs and find treasure for bonus XP rewards.',
  },
]
---

<section class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="font-mono-heading font-bold text-4xl md:text-5xl text-white mb-4">
        Everything a pet needs
      </h2>
      <p class="text-[var(--text-secondary)] text-lg max-w-xl mx-auto">
        More than a widget — a full-featured companion that grows with your coding journey.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {features.map(f => (
        <div class="bg-[var(--card)] border border-[var(--border)] rounded-2xl p-6 hover:border-[rgba(217,119,87,0.2)] transition-colors">
          <div class="text-3xl mb-4">{f.icon}</div>
          <h3 class="font-mono-heading font-bold text-white text-lg mb-2">{f.title}</h3>
          <p class="text-[var(--text-secondary)] text-sm leading-relaxed">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
