---

import Heart from '../assets/icons/heart.svg';

// 8-bit pixel art icons as inline SVG strings
const features = [
  {
    id: 'tracking',
    title: 'Live Session Tracking',
    description:
      'Your crab watches Claude Code work and reacts with animated expressions in real-time.',
  },
  {
    id: 'permissions',
    title: 'Permission Handling',
    description:
      'Approve or deny tool permissions directly from the floating widget without switching windows.',
  },
  {
    id: 'petcare',
    title: 'Pet Care',
    description:
      'Feed, pet, and poke your crab. Watch hunger and happiness drain over time if you neglect it.',
  },
  {
    id: 'levelup',
    title: 'Level Up',
    description:
      'Earn XP from coding sessions and interactions. Level up to unlock 8 unique accessories.',
  },
  {
    id: 'achievements',
    title: 'Achievements',
    description:
      '12 badges to unlock — from your first poke to 30-day coding streaks and beyond.',
  },
  {
    id: 'minigames',
    title: 'Mini-Games',
    description:
      'Simon Says pops up randomly. Catch bugs and find treasure for bonus XP rewards.',
  },
];
---

<section class="py-24 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="font-mono-heading font-bold text-4xl md:text-5xl text-white mb-4">
        Everything a pet needs
      </h2>
      <p class="text-(--text-secondary) text-lg max-w-xl mx-auto">
        More than a widget — a full-featured companion that grows with your coding journey.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {features.map(f => (
        <div class="bg-(--card) border border-(--border) rounded-2xl p-6 hover:border-[rgba(217,119,87,0.2)] transition-colors">
          <div class="mb-4">
            {f.id === 'tracking' && (
              <!-- Eye icon — pixel art -->
              <svg width="32" height="32" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" style="image-rendering: pixelated">
                <rect x="4" y="5" width="8" height="6" fill="#D97757"/>
                <rect x="3" y="6" width="1" height="4" fill="#D97757"/>
                <rect x="12" y="6" width="1" height="4" fill="#D97757"/>
                <rect x="2" y="7" width="1" height="2" fill="#D97757"/>
                <rect x="13" y="7" width="1" height="2" fill="#D97757"/>
                <rect x="6" y="7" width="2" height="2" fill="#0A0A0A"/>
                <rect x="10" y="7" width="2" height="2" fill="#0A0A0A"/>
                <rect x="7" y="7" width="1" height="1" fill="#FFFFFF"/>
                <rect x="11" y="7" width="1" height="1" fill="#FFFFFF"/>
              </svg>
            )}
            {f.id === 'permissions' && (
              <!-- Shield/lock icon — pixel art -->
              <svg width="32" height="32" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" style="image-rendering: pixelated">
                <rect x="5" y="2" width="6" height="4" fill="none" stroke="#D97757" stroke-width="1"/>
                <rect x="4" y="6" width="8" height="7" fill="#D97757"/>
                <rect x="7" y="8" width="2" height="2" fill="#0A0A0A"/>
                <rect x="7" y="10" width="2" height="1" fill="#0A0A0A"/>
              </svg>
            )}
            {f.id === 'petcare' && (
              <!-- Heart icon — pixel art -->
              <Heart />
            )}
            {f.id === 'levelup' && (
              <!-- Arrow up / star icon — pixel art -->
              <svg width="32" height="32" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" style="image-rendering: pixelated">
                <rect x="7" y="2" width="2" height="1" fill="#D97757"/>
                <rect x="6" y="3" width="4" height="1" fill="#D97757"/>
                <rect x="5" y="4" width="6" height="1" fill="#D97757"/>
                <rect x="4" y="5" width="8" height="1" fill="#D97757"/>
                <rect x="3" y="6" width="10" height="1" fill="#D97757"/>
                <rect x="7" y="7" width="2" height="6" fill="#D97757"/>
              </svg>
            )}
            {f.id === 'achievements' && (
              <!-- Trophy icon — pixel art -->
              <svg width="32" height="32" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" style="image-rendering: pixelated">
                <rect x="4" y="2" width="8" height="1" fill="#D97757"/>
                <rect x="4" y="3" width="8" height="5" fill="#D97757"/>
                <rect x="2" y="3" width="2" height="3" fill="#D97757"/>
                <rect x="12" y="3" width="2" height="3" fill="#D97757"/>
                <rect x="5" y="8" width="6" height="1" fill="#D97757"/>
                <rect x="6" y="9" width="4" height="1" fill="#D97757"/>
                <rect x="7" y="10" width="2" height="1" fill="#D97757"/>
                <rect x="5" y="11" width="6" height="1" fill="#D97757"/>
                <rect x="4" y="12" width="8" height="1" fill="#D97757"/>
              </svg>
            )}
            {f.id === 'minigames' && (
              <!-- Game controller — pixel art -->
              <svg width="32" height="32" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg" style="image-rendering: pixelated">
                <rect x="3" y="5" width="10" height="6" fill="#D97757"/>
                <rect x="2" y="6" width="1" height="4" fill="#D97757"/>
                <rect x="13" y="6" width="1" height="4" fill="#D97757"/>
                <rect x="1" y="7" width="1" height="2" fill="#D97757"/>
                <rect x="14" y="7" width="1" height="2" fill="#D97757"/>
                <!-- D-pad -->
                <rect x="5" y="7" width="1" height="3" fill="#0A0A0A"/>
                <rect x="4" y="8" width="3" height="1" fill="#0A0A0A"/>
                <!-- Buttons -->
                <rect x="10" y="7" width="1" height="1" fill="#0A0A0A"/>
                <rect x="12" y="7" width="1" height="1" fill="#0A0A0A"/>
                <rect x="11" y="9" width="1" height="1" fill="#0A0A0A"/>
              </svg>
            )}
          </div>
          <h3 class="font-mono-heading font-bold text-white text-lg mb-2">{f.title}</h3>
          <p class="text-(--text-secondary) text-sm leading-relaxed">{f.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
