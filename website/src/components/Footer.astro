---
import Heart from '../assets/icons/heart.svg';
import X from '../assets/icons/x.svg';
import GitHub from '../assets/icons/github.svg';
---

<footer class="border-t border-(--border) py-12 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row items-center justify-between gap-4">
      <p class="text-(--text-secondary) text-sm">
        Made with <Heart class="size-4 inline-block" /> and Claude Code
      </p>

      <div class="flex items-center gap-4 text-sm text-(--text-secondary)">
        <a
          href="https://x.com/cpenned"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-white transition-colors"
        >
          <X class="size-4" />
        </a>
        <a
          href="https://github.com/cpenned/clawdagotchi"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-white transition-colors"
        >
          <GitHub class="size-4" />
        </a>
        <a
          href="https://github.com/cpenned/clawdagotchi/blob/main/LICENSE"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-white transition-colors"
        >
          License
        </a>
        <a
          href="https://github.com/cpenned/clawdagotchi/releases"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-white transition-colors"
        >
          Releases
        </a>
      </div>
    </div>

    <div class="mt-8 pt-6">
      <p class="text-[rgba(255,255,255,0.2)] text-xs text-center">
        Not affiliated with Anthropic. Clawd is a trademark of Anthropic.
      </p>
    </div>
  </div>
</footer>
