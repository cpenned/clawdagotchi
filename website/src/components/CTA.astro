---
---

<section class="py-24 px-6">
  <div class="max-w-2xl mx-auto text-center">
    <div class="bg-(--card) border border-(--border) rounded-3xl p-12">
      <h2 class="font-mono-heading font-bold text-4xl md:text-5xl text-white mb-4">
        Get Clawdagotchi
      </h2>
      <p class="text-(--text-secondary) text-lg mb-8">
        Free, open source, no account needed.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8">
        <a
          href="https://github.com/cpenned/clawdagotchi/releases/latest/download/Clawdagotchi.dmg"
          class="flex items-center gap-2 bg-(--accent) hover:bg-(--accent-hover) text-white px-8 py-3.5 rounded-xl font-medium text-base transition-colors w-full sm:w-auto justify-center"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
            <polyline points="7 10 12 15 17 10"/>
            <line x1="12" y1="15" x2="12" y2="3"/>
          </svg>
          Download for macOS
        </a>
        <a
          href="https://github.com/cpenned/clawdagotchi"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 border border-[rgba(255,255,255,0.12)] hover:border-[rgba(255,255,255,0.24)] text-white px-8 py-3.5 rounded-xl font-medium text-base transition-colors w-full sm:w-auto justify-center"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
          </svg>
          View on GitHub
        </a>
      </div>

      <div class="flex items-center justify-center gap-2 text-(--text-secondary) text-sm mb-4">
        <span>or install with</span>
        <code class="bg-[rgba(255,255,255,0.06)] border border-[rgba(255,255,255,0.08)] rounded-md px-2 py-0.5 text-(--accent) font-mono text-xs select-all">brew install --cask cpenned/tap/clawdagotchi</code>
      </div>

      <p class="text-(--text-secondary) text-sm">
        Requires macOS 15+ and Claude Code
      </p>
    </div>
  </div>
</section>
