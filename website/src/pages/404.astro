---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 — Page Not Found · Clawdagotchi" description="This page doesn't exist.">
  <div class="min-h-screen flex flex-col items-center justify-center px-6 text-center relative">
    <!-- Orange glow behind crab -->
    <div aria-hidden="true" style="position:absolute;top:50%;left:50%;transform:translate(-50%,-60%);width:400px;height:400px;pointer-events:none;background:radial-gradient(ellipse,rgba(217,119,87,0.10) 0%,transparent 70%);"></div>

    <!-- Crab — exact Swift geometry (viewBox 86x80, offsets 10/22) -->
    <div class="mb-8 relative">
      <svg width="100" height="100" viewBox="0 0 86 80" fill="none" xmlns="http://www.w3.org/2000/svg" style="image-rendering:pixelated">
        <!-- Antennae -->
        <rect x="10" y="35" width="6" height="13" fill="#D97757" opacity="0.4"/>
        <rect x="70" y="35" width="6" height="13" fill="#D97757" opacity="0.4"/>
        <!-- Legs (droopy) -->
        <rect x="16" y="61" width="6" height="16" fill="#D97757" opacity="0.4"/>
        <rect x="28" y="61" width="6" height="12" fill="#D97757" opacity="0.4"/>
        <rect x="52" y="61" width="6" height="12" fill="#D97757" opacity="0.4"/>
        <rect x="64" y="61" width="6" height="16" fill="#D97757" opacity="0.4"/>
        <!-- Body -->
        <rect x="16" y="22" width="54" height="39" fill="#D97757" opacity="0.5"/>
        <!-- Eyes (X marks — pixel art) -->
        <!-- Left X -->
        <rect x="22" y="34" width="2" height="2" fill="#1A1A1A"/>
        <rect x="24" y="36" width="2" height="2" fill="#1A1A1A"/>
        <rect x="26" y="34" width="2" height="2" fill="#1A1A1A"/>
        <rect x="22" y="38" width="2" height="2" fill="#1A1A1A"/>
        <rect x="26" y="38" width="2" height="2" fill="#1A1A1A"/>
        <!-- Right X -->
        <rect x="56" y="34" width="2" height="2" fill="#1A1A1A"/>
        <rect x="58" y="36" width="2" height="2" fill="#1A1A1A"/>
        <rect x="60" y="34" width="2" height="2" fill="#1A1A1A"/>
        <rect x="56" y="38" width="2" height="2" fill="#1A1A1A"/>
        <rect x="60" y="38" width="2" height="2" fill="#1A1A1A"/>
      </svg>
    </div>

    <h1 class="font-mono-heading font-bold text-6xl md:text-8xl text-white mb-4">404</h1>
    <p class="text-(--text-secondary) text-xl mb-2">Page not found</p>
    <p class="text-(--text-secondary) text-base mb-10 max-w-sm">
      Your crab searched everywhere but couldn't find this page.
    </p>

    <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-6">
      <a
        href="/"
        class="flex items-center gap-2 bg-(--accent) hover:bg-(--accent-hover) text-white px-6 py-3 rounded-xl font-medium text-base transition-colors"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m12 19-7-7 7-7"/>
          <path d="M19 12H5"/>
        </svg>
        Back home
      </a>
      <a
        href="https://github.com/cpenned/clawdagotchi"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 border border-[rgba(255,255,255,0.12)] hover:border-[rgba(255,255,255,0.24)] text-white px-6 py-3 rounded-xl font-medium text-base transition-colors"
      >
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.17 6.839 9.49.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.604-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0 1 12 6.836c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.741 0 .267.18.578.688.48C19.138 20.167 22 16.418 22 12c0-5.523-4.477-10-10-10z"/>
        </svg>
        View on GitHub
      </a>
    </div>

    <div class="flex items-center justify-center gap-2 text-(--text-secondary) text-sm">
      <span>or</span>
      <code class="bg-[rgba(255,255,255,0.06)] border border-[rgba(255,255,255,0.08)] rounded-md px-2 py-0.5 text-(--accent) font-mono text-xs select-all">brew install --cask cpenned/tap/clawdagotchi</code>
    </div>
  </div>
</Layout>
